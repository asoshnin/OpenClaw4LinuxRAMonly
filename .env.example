# .env.example — OpenClaw for Linux
# Copy this file to .env and fill in your values.
# OpenClaw reads env vars directly from the environment — do NOT commit .env to git.
# Usage: export VAR=value  OR  add to ~/.bashrc / ~/.zshrc
# (Tip: 'source .env' also works if your shell supports it)

# ─── Obsidian Bidirectional Sync (Sprint 7+) ─────────────────────────────────
# Required to use any vault sync features (write-to-vault, ingest-vault-note).
# Get this from: Obsidian → Settings → Community Plugins → Local REST API → API Key
OBSIDIAN_API_KEY=your-obsidian-local-rest-api-key-here

# URL of the Local REST API plugin (default shown — only change if you use HTTPS/port 27124)
OBSIDIAN_BASE_URL=http://127.0.0.1:27123

# Absolute path to your Obsidian vault root (used by setup.sh for folder bootstrap)
# Example: /home/yourname/obsidian-vault
OBSIDIAN_VAULT_PATH=

# ─── OpenClaw Workspace ────────────────────────────────────────────────────────
# Where factory.db, REGISTRY.md, and agent profiles are stored.
# Default: ~/.openclaw/workspace — only set this if you want a custom location.
OPENCLAW_WORKSPACE=~/.openclaw/workspace

# ─── Cloud Distillation (non-sensitive logs only) ─────────────────────────────
# Required for cloud-based log distillation via Google Gemini.
# Non-sensitive logs only — the router NEVER sends sensitive data to the cloud.
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
